DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MAX_CONCURRENCY=20
# Optional on Netlify for Dashboard reads only (uses /api proxy if empty).
# REQUIRED for Score uploads (10+ min job — Netlify /api proxy times out at ~26s):
#   VITE_API_URL=https://wrestlingleads-production.up.railway.app
VITE_API_URL=
# App login (frontend). Default is admin123 if unset.
VITE_APP_PASSWORD=admin123
WUFOO_WEBHOOK_SECRET=
HUBSPOT_ACCESS_TOKEN=
# Lead routing emails — Google Workspace / Gmail (App Password: Account → Security → App passwords)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=sales@wrestlingmindset.com
SMTP_PASSWORD=
ROUTING_FROM_EMAIL=Leads Wrestling <sales@wrestlingmindset.com>
