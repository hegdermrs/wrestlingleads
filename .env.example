DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MAX_CONCURRENCY=20
# Optional on Netlify for Dashboard reads only (uses /api proxy if empty).
# REQUIRED for Score uploads (10+ min job — Netlify /api proxy times out at ~26s):
#   VITE_API_URL=https://wrestlingleads-production.up.railway.app
# Do not add /api — Netlify already proxies /api to Railway; Railway paths are /auth, /health, etc.
VITE_API_URL=
# App login — password hash stored in SQLite on the data volume (data/app_auth.db).
# APP_PASSWORD seeds the hash only on first run if no password exists yet.
APP_PASSWORD=admin123
WUFOO_WEBHOOK_SECRET=
# HubSpot — upsert contact on route (create by email or update by Record ID / email search)
# Private app scopes: crm.objects.contacts.read, crm.objects.contacts.write
# Create custom properties in HubSpot: ai_score, ai_tier, lw_assigned_rep, lw_route_reason, lw_assigned_at (see config/hubspot_field_map.json)
# Optional per rep in routing rules: "hubspot_owner_id": "12345678" (Settings → Users → copy owner ID)
HUBSPOT_ACCESS_TOKEN=
# Email — pick ONE method on Railway:
# A) Gmail SMTP (Railway Pro plan only — blocked on Hobby)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=mindset@wrestlingmindset.com
SMTP_PASSWORD=
ROUTING_FROM_EMAIL=Leads Wrestling <mindset@wrestlingmindset.com>
# B) Resend HTTPS API (works on Railway Hobby — verify wrestlingmindset.com in Resend)
RESEND_API_KEY=
# No DNS yet? Send all rep notifications to one inbox (must be your Resend signup email):
RESEND_SANDBOX_TO=
# n8n — POST lead assignments here (works without DNS; runs alongside Resend when both set)
N8N_WEBHOOK_URL=
N8N_WEBHOOK_SECRET=
